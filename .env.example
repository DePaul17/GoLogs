# Copiez ce fichier en ".env" à la racine du projet et remplissez les valeurs.
# Ne commitez jamais le fichier .env (déjà dans .gitignore).

# URL utilisée dans les liens de réinitialisation (doit correspondre à runserver)
SITE_URL=http://127.0.0.1:8000

# --- Gmail (gratuit, compte Google requis) ---
# 1. Activez la validation en 2 étapes sur https://myaccount.google.com/security
# 2. Créez un "Mot de passe d'application" : https://myaccount.google.com/apppasswords
# 3. Utilisez ce mot de passe (16 caractères) dans EMAIL_HOST_PASSWORD, pas votre mot de passe Gmail

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=votre.adresse@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=votre.adresse@gmail.com

# --- Alternative : laissez EMAIL_HOST vide pour le mode développement ---
# Le lien s'affichera dans le terminal du serveur (pas d'e-mail réel).
